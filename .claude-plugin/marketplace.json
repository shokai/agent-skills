{
  "name": "shokai-agent-skills",
  "owner": {
    "name": "shokai"
  },
  "metadata": {
    "description": "shokai's Claude Code Agent Skills collection",
    "version": "1.0.0",
    "pluginRoot": "./plugins"
  },
  "plugins": [
    {
      "name": "library-update-review",
      "source": "./plugins/library-update-review",
      "description": "ライブラリ更新pull requestのレビュー手順。dependabot/renovatebot PRの分析、release note調査、コード更新、過去の失敗調査を行う。",
      "version": "1.0.0",
      "author": {
        "name": "shokai"
      },
      "repository": "https://github.com/shokai/agent-skills",
      "license": "MIT",
      "keywords": ["library-update", "dependabot", "renovatebot", "review", "npm"],
      "category": "code-review"
    },
    {
      "name": "codex-consultation",
      "source": "./plugins/codex-consultation",
      "description": "Codex CLIにセカンドオピニオンを求めるスキル。「codexと相談して」「codexに聞いて」で発動する。",
      "version": "1.2.0",
      "author": {
        "name": "shokai"
      },
      "repository": "https://github.com/shokai/agent-skills",
      "license": "MIT",
      "keywords": ["codex", "openai", "consultation", "second-opinion"],
      "category": "ai-collaboration"
    },
    {
      "name": "conversation-context",
      "source": "./plugins/conversation-context",
      "description": "対話コンテキストのexport/importスキル。会話で共有された目的・意図・設計判断・制約条件を .dev/contexts/ に書き出し、別セッションやレビューで読み込む。1対多のコンテキスト共有により、複数のsub PRをまとめたfeature PRのレビューやコードの自動改善に便利。",
      "version": "1.1.0",
      "author": {
        "name": "shokai"
      },
      "repository": "https://github.com/shokai/agent-skills",
      "license": "MIT",
      "keywords": ["context", "export", "import", "session", "handoff"],
      "category": "workflow"
    },
    {
      "name": "sanity-review",
      "source": "./plugins/sanity-review",
      "description": "PRのレビュー報告書を作成する。bugや脆弱性の調査だけでなく、exportされた対話コンテキスト・PR概要欄・実装されたコードの整合性を確認し、実装者の正気を疑う。",
      "version": "1.1.0",
      "author": {
        "name": "shokai"
      },
      "repository": "https://github.com/shokai/agent-skills",
      "license": "MIT",
      "keywords": ["pull-request", "review", "sanity", "bug-hunting", "context", "codex"],
      "category": "code-review"
    },
    {
      "name": "prose-proofreading",
      "source": "./plugins/prose-proofreading",
      "description": "Markdownドキュメントの文章校正。ガイドラインに基づいて文体の問題を検出し、修正案を提示する。",
      "version": "1.0.0",
      "author": {
        "name": "shokai"
      },
      "repository": "https://github.com/shokai/agent-skills",
      "license": "MIT",
      "keywords": ["markdown", "proofreading", "writing", "style", "documentation"],
      "category": "documentation"
    }
  ]
}
